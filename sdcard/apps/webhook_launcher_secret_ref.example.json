{
  "version": 1,
  "commands": [
    {
      "name": "Deploy With Secret Ref",
      "method": "POST",
      "url": "https://example.com/webhook/deploy-preview",
      "confirm": true,
      "headers": {
        "Content-Type": "application/json",
        "Authorization": {
          "secretRef": "webhooks.deploy.authorization"
        }
      },
      "body": {
        "source": "cardputer",
        "action": "deploy-preview"
      }
    }
  ]
}
