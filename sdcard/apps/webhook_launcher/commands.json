{
  "version": 1,
  "commands": [
    {
      "name": "Deploy Preview",
      "method": "POST",
      "url": "https://example.com/webhook/deploy-preview",
      "confirm": true,
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer REPLACE_WITH_TOKEN"
      },
      "body": {
        "source": "cardputer",
        "action": "deploy-preview"
      }
    },
    {
      "name": "Ping Healthcheck",
      "method": "GET",
      "url": "https://example.com/webhook/healthcheck",
      "confirm": false,
      "headers": {
        "X-Device": "cardputer-launcher-sdk"
      }
    },
    {
      "name": "Deploy to Environment",
      "method": "POST",
      "url": "https://example.com/webhook/deploy/{{input.env}}",
      "category": "deploy",
      "description": "Trigger a deploy for a chosen environment.",
      "risk": "high",
      "confirm": true,
      "requirePreview": true,
      "inputs": [
        {
          "key": "env",
          "kind": "choice",
          "label": "Environment",
          "choices": ["staging", "prod"],
          "default": "staging"
        },
        {
          "key": "reason",
          "kind": "text",
          "label": "Reason",
          "maxLength": 40,
          "required": false
        },
        {
          "key": "notify",
          "kind": "boolean",
          "label": "Notify Slack?",
          "default": "false"
        }
      ],
      "headers": {
        "Content-Type": "application/json",
        "X-Reason": "{{input.reason}}"
      },
      "body": {
        "source": "cardputer",
        "environment": "{{input.env}}",
        "notify": "{{input.notify}}"
      }
    }
  ]
}
